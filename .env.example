APP_ENV=local
APP_PORT=8080
APP_NAME=erp-platform

DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp
DB_USER=erp
DB_PASSWORD=erp
DB_SSL_MODE=disable
DATABASE_URL=postgres://erp:erp@localhost:5432/erp?sslmode=disable

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
QUEUE_URL=redis://localhost:6379/1

JWT_SECRET=change-me-local-only
JWT_ACCESS_TTL_MINUTES=60
AUTH_MOCK_EMAIL=admin@example.local
AUTH_MOCK_PASSWORD=local-only-mock-password
AUTH_MOCK_ACCESS_TOKEN=local-dev-access-token

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=erp-local
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_USE_SSL=false
S3_USE_PATH_STYLE=true

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@example.local

OPENAPI_PATH=packages/openapi/openapi.yaml

NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_MOCK_AUTH_STATE=signed-in
