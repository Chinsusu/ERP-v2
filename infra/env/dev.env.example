# Copy to infra/env/dev.env before deploying a shared dev environment.
APP_ENV=dev
APP_NAME=erp-platform
APP_VERSION=dev
APP_PORT=8080
ERP_IMAGE_TAG=dev
PUBLIC_HTTP_PORT=8088

POSTGRES_DB=erp_dev
POSTGRES_USER=erp_dev
POSTGRES_PASSWORD=erp_dev_change_me
DB_HOST=postgres
DB_PORT=5432
DB_SSL_MODE=disable
DATABASE_URL=postgres://erp_dev:erp_dev_change_me@postgres:5432/erp_dev?sslmode=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
QUEUE_URL=redis://redis:6379/1

JWT_SECRET=change-me-dev-only
JWT_ACCESS_TTL_MINUTES=60
AUTH_MOCK_EMAIL=admin@example.local
AUTH_MOCK_PASSWORD=local-only-mock-password
AUTH_MOCK_ACCESS_TOKEN=local-dev-access-token

S3_ENDPOINT=http://minio:9000
S3_BUCKET=erp-dev
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_USE_SSL=false
S3_USE_PATH_STYLE=true

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply-dev@example.local

LOG_LEVEL=info
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_VERSION=dev
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_MOCK_AUTH_STATE=signed-out
AUTH_COOKIE_SECURE=false

SMOKE_BASE_URL=http://localhost:8088
SMOKE_API_URL=http://localhost:8088/api/v1/health
SMOKE_WEB_URL=http://localhost:8088/
