# Copy to infra/env/staging.env before deploying staging.
APP_ENV=staging
APP_NAME=erp-platform
APP_VERSION=staging
APP_PORT=8080
ERP_IMAGE_TAG=staging
PUBLIC_HTTP_PORT=8089

POSTGRES_DB=erp_staging
POSTGRES_USER=erp_staging
POSTGRES_PASSWORD=erp_staging_change_me
DB_HOST=postgres
DB_PORT=5432
DB_SSL_MODE=disable
DATABASE_URL=postgres://erp_staging:erp_staging_change_me@postgres:5432/erp_staging?sslmode=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
QUEUE_URL=redis://redis:6379/1

JWT_SECRET=change-me-staging-only
JWT_ACCESS_TTL_MINUTES=60
AUTH_MOCK_EMAIL=admin@example.local
AUTH_MOCK_PASSWORD=local-only-mock-password
AUTH_MOCK_ACCESS_TOKEN=staging-access-token

S3_ENDPOINT=http://minio:9000
S3_BUCKET=erp-staging
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_USE_SSL=false
S3_USE_PATH_STYLE=true

SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply-staging@example.local

LOG_LEVEL=info
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_VERSION=staging
NEXT_PUBLIC_API_BASE_URL=https://staging-erp.example.vn/api/v1
NEXT_PUBLIC_MOCK_AUTH_STATE=signed-in
AUTH_COOKIE_SECURE=true

SMOKE_BASE_URL=http://localhost:8089
SMOKE_API_URL=http://localhost:8089/api/v1/health
SMOKE_WEB_URL=http://localhost:8089/
